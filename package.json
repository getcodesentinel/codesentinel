{
  "name": "codesentinel-workspace",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a",
  "scripts": {
    "build": "pnpm -r --filter \"!./packages/cli\" build && pnpm --filter ./packages/cli build",
    "start": "pnpm --filter ./packages/cli exec node dist/index.js",
    "start:dev": "pnpm --filter ./packages/cli dev",
    "dev": "pnpm -r --filter \"!./packages/cli\" build && pnpm --filter ./packages/cli dev",
    "lint": "eslint .",
    "typecheck": "pnpm -r --filter './packages/*' exec tsc --noEmit -p tsconfig.json",
    "lint:staged": "lint-staged",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "prepare": "husky",
    "release": "semantic-release",
    "test": "pnpm -r test",
    "publish:cli": "pnpm --filter ./packages/cli exec npm publish --access public",
    "verify:cli-package": "node scripts/verify-cli-package.mjs"
  },
  "lint-staged": {
    "*.{cjs,css,cts,html,js,json,md,mjs,mts,scss,ts,tsx,yaml,yml}": "prettier --write",
    "*.{cjs,cts,js,mjs,mts,ts,tsx}": "eslint --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.3",
    "semantic-release": "^25.0.3",
    "tsup": "^8.2.4",
    "tsx": "^4.19.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
